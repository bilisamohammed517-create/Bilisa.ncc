t=int(input())
for i in range(t):
    n=int(input())
    l1=[]
    l2=[]
    
    for i in range(2,n+1):
        l1.append(i)
    for i in range(2,n+1):
        best=0
        for j in range(1,n+1):
            if i*j<=n:
                best+=i*j
            else:
                break    
        l2.append(best)
    x=l2.index(max(l2))
    print(l1[x])
