class Solution:
    def majorityElement(self, nums: List[int]) -> int:
        
        dic={}
        for i in nums:
            if i in dic:
                dic[i]+1
            else:
                dic[i]=nums.count(i)    
        l=[]
        for i in dic:
            l.append((dic[i],i))
        l.sort(reverse=True) 
        return l[0][1]   
        
