class Solution:
    def findAnagrams(self, s: str, p: str) -> List[int]:
         l=[]
         p=sorted(p)
         left=0
         right=len(p)
         while right<=len(s):
            st=s[left:right]
            if sorted(st)==p:
                l.append(left)
            left+=1
            right+=1
         return l                      
